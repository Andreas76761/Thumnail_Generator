# ======== API Keys ========

# Anthropic Claude (https://console.anthropic.com/)
VITE_CLAUDE_API_KEY=sk-ant-

# OpenAI (https://platform.openai.com/)
VITE_OPENAI_API_KEY=sk-

# Google Gemini (https://makersuite.google.com/app/apikey)
VITE_GEMINI_API_KEY=

# Notion (https://notion.so/settings/integrations)
VITE_NOTION_API_KEY=secret_
VITE_NOTION_DATABASE_ID=

# ======== App Configuration ========

# Upload Limits
VITE_MAX_FILE_SIZE=50000000
VITE_MAX_FILES_AT_ONCE=5

# Thumbnail Generation
VITE_THUMBNAIL_WIDTH=800
VITE_THUMBNAIL_HEIGHT=600

# Voice Chat
VITE_SPEECH_LANG=de-DE
VITE_TTS_LANG=de-DE
VITE_ENABLE_VOICE_CHAT=true

# Design Generator
VITE_DESIGN_WIDTH=800
VITE_DESIGN_HEIGHT=600
VITE_ENABLE_DESIGN_GENERATOR=true

# OCR
VITE_OCR_LANGUAGE=deu
VITE_ENABLE_OCR=true

# Notion Sync
VITE_NOTION_SYNC_INTERVAL=5000
VITE_NOTION_BATCH_SIZE=10

# Logging
VITE_LOG_LEVEL=info
